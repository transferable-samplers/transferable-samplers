  "extras": {
    "enforce_tags": true,
    "ignore_warnings": false,
    "print_config": true
  },
  "init_ckpt_path": null,
  "init_hf_state_dict_path": null,
  "logger": {
    "csv": {
      "_target_": "lightning.pytorch.loggers.csv_logs.CSVLogger",
      "name": "csv/",
      "prefix": "",
      "save_dir": "${paths.output_dir}"
    },
    "wandb": {
      "_target_": "lightning.pytorch.loggers.wandb.WandbLogger",
      "anonymous": null,
      "entity": "openproblems-comp",
      "group": "",
      "id": null,
      "job_type": "",
      "log_model": false,
      "offline": false,
      "prefix": "",
      "project": "self-consume-bg",
      "save_dir": "${paths.output_dir}",
      "tags": "${tags}"
    }
  },
  "model": {
    "_target_": "transferable_samplers.models.normalizing_flow_module.NormalizingFlowModule",
    "compile_net": false,
    "mean_free_prior": false,
    "net": {
      "_target_": "transferable_samplers.nn.tarflow.tarflow.TarFlow",
      "channels": 384,
      "cond_embed": {
        "_target_": "transferable_samplers.nn.embedder.ConditionalEmbedder",
        "hidden_dim": "${model.net.channels}",
        "output_dim": "${model.net.channels}",
        "sinusoid_div_value": 1000
      },
      "input_dimension": 3,
      "layers_per_block": 8,
      "max_num_tokens": "${data.num_atoms}",
      "num_blocks": 8,
      "permutation_keys": [
        "n2c_residue-by-residue_standard",
        "n2c_residue-by-residue_standard_flip"
      ],
      "pos_embed_type": "sinusoidal",
      "use_adapt_ln": false,
      "use_qkln": true,
      "use_transition": false
    },
    "optimizer": {
      "_partial_": true,
      "_target_": "torch.optim.AdamW",
      "betas": [
        0.9,
        0.95
      ],
      "lr": 0.0001,
      "weight_decay": 0.0004
    },
    "prior": {
      "_target_": "transferable_samplers.models.priors.normal_distribution.NormalDistribution",
      "mean_free": false,
      "num_dimensions": "${data.num_dimensions}"
    },
    "scheduler": {
      "_partial_": true,
      "_target_": "torch.optim.lr_scheduler.OneCycleLR",
      "anneal_strategy": "cos",
      "cycle_momentum": false,
      "div_factor": 500.0,
      "final_div_factor": 1.0,
      "max_lr": "${model.optimizer.lr}",
      "pct_start": 0.05,
      "total_steps": "${trainer.max_epochs}"
    },
    "source_energy_config": {
      "_target_": "transferable_samplers.utils.dataclasses.SourceEnergyConfig",
      "energy_batch_size": 5000,
      "grad_batch_size": 5000,
      "sample_batch_size": 5000,
      "use_com_adjustment": true
    },
    "train_from_buffer": false
  },
  "num_sanity_val_steps": 0,
  "paths": {
    "data_dir": "${paths.scratch_dir}/many-peptides-md",
    "log_dir": "${paths.scratch_dir}/logs",
    "output_dir": "${hydra:runtime.output_dir}",
    "scratch_dir": "${oc.env:SCRATCH_DIR}/transferable-samplers",
    "work_dir": "${hydra:runtime.cwd}"
  },
  "resume_ckpt_path": null,
  "seed": null,
  "tags": [
    "dev"
  ],
  "task_name": "train",
  "torch_num_threads": 2,
  "trainer": {
    "_target_": "lightning.pytorch.trainer.Trainer",
    "accelerator": "gpu",
    "check_val_every_n_epoch": 50,
    "default_root_dir": "${paths.output_dir}",
    "deterministic": false,
    "devices": 1,
    "gradient_clip_val": 1.0,
    "inference_mode": false,
    "limit_test_batches": 1,
    "limit_train_batches": 1000,
    "limit_val_batches": 1,
    "max_epochs": 500,
    "min_epochs": 1,
    "plugins": [
      {
        "_target_": "lightning.pytorch.plugins.environments.SLURMEnvironment",
        "auto_requeue": false
      }
    ]
  }
}
