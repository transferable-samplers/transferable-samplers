{
  "callbacks": {
    "ema": {
      "_target_": "transferable_samplers.callbacks.ema_weight_averaging.EMAWeightAveraging",
      "decay": 0.999
    },
    "loss_evaluation": {
      "_target_": "transferable_samplers.callbacks.loss_evaluation_callback.LossEvaluationCallback",
      "batch_size": 256
    },
    "lr_monitor": {
      "_target_": "lightning.pytorch.callbacks.LearningRateMonitor",
      "logging_interval": "step"
    },
    "model_checkpoint_last": {
      "_target_": "lightning.pytorch.callbacks.ModelCheckpoint",
      "dirpath": "${paths.output_dir}/checkpoints",
      "every_n_epochs": 1,
      "monitor": null,
      "save_last": true,
      "save_on_train_epoch_end": true,
      "save_top_k": 1,
      "verbose": true
    },
    "model_checkpoint_loss": {
      "_target_": "lightning.pytorch.callbacks.ModelCheckpoint",
      "auto_insert_metric_name": false,
      "dirpath": "${paths.output_dir}/checkpoints",
      "every_n_epochs": null,
      "every_n_train_steps": null,
      "filename": "epoch_{epoch:03d}_loss",
      "mode": "min",
      "monitor": "train/loss",
      "save_last": false,
      "save_on_train_epoch_end": null,
      "save_top_k": 1,
      "save_weights_only": false,
      "train_time_interval": null,
      "verbose": false
    },
    "model_checkpoint_resampled_energy_w2": {
      "_target_": "lightning.pytorch.callbacks.ModelCheckpoint",
      "auto_insert_metric_name": false,
      "dirpath": "${paths.output_dir}/checkpoints",
      "every_n_epochs": null,
      "every_n_train_steps": null,
      "filename": "epoch_{epoch:03d}_resampled_energy_w2",
      "mode": "min",
      "monitor": "val/mean/resampled/energy-w2",
      "save_last": false,
      "save_on_train_epoch_end": null,
      "save_top_k": 1,
      "save_weights_only": false,
      "train_time_interval": null,
      "verbose": false
    },
    "model_summary": {
      "_target_": "lightning.pytorch.callbacks.RichModelSummary",
      "max_depth": 2
    },
    "sampling_evaluation": {
      "_target_": "transferable_samplers.callbacks.sampling_evaluation_callback.SamplingEvaluationCallback",
      "evaluator": {
        "_target_": "transferable_samplers.evaluation.evaluator.PeptideEnsembleEvaluator"
      },
      "sampler": {
        "_target_": "transferable_samplers.samplers.snis_sampler.SNISSampler",
        "num_samples": 5000
      }
    }
  },
  "check_val_every_n_epoch": 100000,
  "data": {
    "_target_": "transferable_samplers.data.many_peptides_datamodule.ManyPeptidesDataModule",
    "batch_size": 512,
    "com_augmentation": true,
    "data_dir": "${paths.data_dir}",
    "num_aa_max": 8,
    "num_aa_min": 2,
    "num_atoms": 178,
    "num_dimensions": 3,
    "num_workers": 2,
    "persistent_workers": false,
    "pin_memory": false,
    "precomputed_std": 0.35,
    "system_cond_ids": [
      "encodings",
      "permutations"
    ],
