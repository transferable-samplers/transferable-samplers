  "extras": {
    "enforce_tags": true,
    "ignore_warnings": false,
    "print_config": true
  },
  "logger": {
    "csv": {
      "_target_": "lightning.pytorch.loggers.csv_logs.CSVLogger",
      "name": "csv/",
      "prefix": "",
      "save_dir": "${paths.output_dir}"
    },
    "wandb": {
      "_target_": "lightning.pytorch.loggers.wandb.WandbLogger",
      "anonymous": null,
      "entity": "openproblems-comp",
      "group": "",
      "id": null,
      "job_type": "",
      "log_model": false,
      "offline": false,
      "prefix": "",
      "project": "self-consume-bg",
      "save_dir": "${paths.output_dir}",
      "tags": "${tags}"
    }
  },
  "model": {
    "_target_": "src.models.normalizing_flow_module.NormalizingFlowLitModule",
    "compile": false,
    "ema_decay": 0.0,
    "mean_free_prior": false,
    "net": {
      "_target_": "src.models.neural_networks.tarflow.tarflow.TarFlow",
      "channels": 384,
      "cond_embed": {
        "_target_": "src.models.neural_networks.embedder.ConditionalEmbedder",
        "hidden_dim": "${model.net.channels}",
        "output_dim": "${model.net.channels}",
        "sinusoid_div_value": 1000
      },
      "input_dimension": 3,
      "layers_per_block": 8,
      "lookahead_conditioning": true,
      "max_num_tokens": "${data.num_atoms}",
      "num_blocks": 8,
      "permutation_keys": [
        "n2c_backbone-first_standard",
        "n2c_residue-by-residue_standard_flip",
        "n2c_backbone-first_standard_flip",
        "n2c_residue-by-residue_standard",
        "n2c_backbone-first_variant",
        "n2c_residue-by-residue_variant_flip",
        "n2c_backbone-first_variant_flip",
        "n2c_residue-by-residue_variant"
      ],
      "pos_embed_type": "sinusoidal",
      "use_adapt_ln": true,
      "use_qkln": true,
      "use_transition": true
    },
    "optimizer": {
      "_partial_": true,
      "_target_": "torch.optim.AdamW",
      "betas": [
        0.9,
        0.95
      ],
      "lr": 0.0001,
      "weight_decay": 0.0004
    },
    "output_dir": "${paths.output_dir}",
    "sampling_config": {
      "batch_size": 5000,
      "clip_reweighting_logits": 0.002,
      "num_proposal_samples": 10000,
      "num_smc_samples": 10000,
      "num_test_proposal_samples": 1000000,
      "use_com_adjustment": true
    },
    "scheduler": {
      "_partial_": true,
      "_target_": "torch.optim.lr_scheduler.OneCycleLR",
      "anneal_strategy": "cos",
      "cycle_momentum": false,
      "div_factor": 500.0,
      "final_div_factor": 1.0,
      "max_lr": "${model.optimizer.lr}",
      "pct_start": 0.05,
      "total_steps": "${trainer.max_epochs}"
    },
    "smc_sampler": null
  },
  "paths": {
    "data_dir": "${paths.scratch_dir}/many-peptides-md",
    "log_dir": "${paths.scratch_dir}/logs",
    "output_dir": "${hydra:runtime.output_dir}",
    "root_dir": "${oc.env:PROJECT_ROOT}",
    "scratch_dir": "${oc.env:SCRATCH_DIR}/transferable-samplers",
    "work_dir": "${hydra:runtime.cwd}"
  },
  "seed": null,
  "state_dict_hf_path": "transferable/prose_up_to_8aa.pth",
  "tags": [
    "dev"
  ],
  "task_name": "eval",
  "test": true,
  "torch_num_threads": 2,
  "trainer": {
    "_target_": "lightning.pytorch.trainer.Trainer",
    "accelerator": "gpu",
    "check_val_every_n_epoch": 10,
    "default_root_dir": "${paths.output_dir}",
    "deterministic": false,
    "devices": 1,
    "gradient_clip_val": 1.0,
    "inference_mode": false,
    "limit_test_batches": 1,
    "limit_val_batches": 1,
    "max_epochs": 40,
    "min_epochs": 1,
    "plugins": [
      {
        "_target_": "lightning.pytorch.plugins.environments.SLURMEnvironment",
        "auto_requeue": false
      }
    ]
  },
  "val": false
}
