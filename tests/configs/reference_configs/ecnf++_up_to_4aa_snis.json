{
  "callbacks": {
    "lr_monitor": {
      "_target_": "lightning.pytorch.callbacks.LearningRateMonitor",
      "logging_interval": "step"
    },
    "model_checkpoint_loss": {
      "_target_": "lightning.pytorch.callbacks.ModelCheckpoint",
      "auto_insert_metric_name": false,
      "dirpath": "${paths.output_dir}/checkpoints",
      "every_n_epochs": null,
      "every_n_train_steps": null,
      "filename": "epoch_{epoch:03d}_loss",
      "mode": "min",
      "monitor": "val/loss",
      "save_last": false,
      "save_on_train_epoch_end": null,
      "save_top_k": 1,
      "save_weights_only": false,
      "train_time_interval": null,
      "verbose": false
    },
    "model_checkpoint_resampled_energy_w2": {
      "_target_": "lightning.pytorch.callbacks.ModelCheckpoint",
      "auto_insert_metric_name": false,
      "dirpath": "${paths.output_dir}/checkpoints",
      "every_n_epochs": null,
      "every_n_train_steps": null,
      "filename": "epoch_{epoch:03d}_resampled_energy_w2",
      "mode": "min",
      "monitor": "val/mean/resampled/energy_w2",
      "save_last": false,
      "save_on_train_epoch_end": null,
      "save_top_k": 1,
      "save_weights_only": false,
      "train_time_interval": null,
      "verbose": false
    },
    "model_checkpoint_time": {
      "_target_": "src.utils.model_checkpoint_callback.FullAndWeightsModelCheckpoint",
      "auto_insert_metric_name": false,
      "dirpath": "${paths.output_dir}/checkpoints",
      "every_n_epochs": 100,
      "every_n_train_steps": null,
      "filename": "epoch_{epoch:03d}_time",
      "mode": "min",
      "monitor": null,
      "save_last": true,
      "save_on_train_epoch_end": true,
      "save_top_k": -1,
      "save_weights_only": false,
      "train_time_interval": null,
      "verbose": false
    },
    "model_summary": {
      "_target_": "lightning.pytorch.callbacks.RichModelSummary",
      "max_depth": 2
    }
  },
  "ckpt_path": null,
  "data": {
    "_target_": "src.data.transferable_peptide_datamodule.TransferablePeptideDataModule",
    "batch_size": 128,
    "data_dir": "${paths.data_dir}",
    "num_aa_max": 4,
    "num_aa_min": 2,
    "num_atoms": 97,
    "num_dimensions": 3,
    "num_eval_samples": 10000,
    "num_workers": 2,
    "pin_memory": false,
    "precomputed_std": 0.28,
    "test_sequences": [
      "AA",
      "CE",
      "CL",
      "DG",
      "DI",
      "FK",
      "HL",
      "HM",
      "IK",
      "IM",
      "KG",
      "LE",
      "MQ",
      "NA",
      "NC",
      "PG",
      "PY",
      "QR",
      "RL",
      "RT",
      "SS",
      "TD",
      "VF",
      "VS",
      "WA",
      "WH",
      "WQ",
      "WS",
      "YC",
      "YQ",
      "ARIP",
      "CCVH",
      "CIPQ",
      "DEMT",
      "DMTL",
      "EHQW",
      "FESD",
      "FYYY",
      "GCDE",
      "GDTI",
      "GGRS",
      "HEAV",
      "HQVS",
      "HYGW",
      "ITYL",
      "KKAP",
      "KLLR",
      "KRWN",
      "NCFG",
      "NEVI",
      "PQIF",
      "QAKR",
      "QWNL",
      "RLMM",
      "SHKS",
      "SVND",
      "TAPF",
      "TMWC",
      "VPFY",
      "WNMA"
    ],
    "val_sequences": [
      "AL",
      "EC",
      "FT",
      "GQ",
      "HV",
      "ND",
      "PF",
      "RS",
      "WI",
      "WY",
      "CAVQ",
      "CVNR",
      "EDWY",
      "GNFL",
      "ISDT",
      "KHAP",
      "KHGM",
      "LFTE",
      "PMWS",
      "YRIQ"
    ]
  },
  "extras": {
    "enforce_tags": true,
    "ignore_warnings": false,
    "print_config": true
  },
  "logger": {
    "csv": {
      "_target_": "lightning.pytorch.loggers.csv_logs.CSVLogger",
      "name": "csv/",
      "prefix": "",
      "save_dir": "${paths.output_dir}"
    },
    "wandb": {
      "_target_": "lightning.pytorch.loggers.wandb.WandbLogger",
      "anonymous": null,
      "entity": "openproblems-comp",
      "group": "",
      "id": null,
      "job_type": "",
      "log_model": false,
      "offline": false,
      "prefix": "",
      "project": "self-consume-bg",
      "save_dir": "${paths.output_dir}",
      "tags": "${tags}"
    }
  },
  "model": {
    "_target_": "src.models.flow_matching_module.FlowMatchLitModule",
    "atol": 0.0001,
    "compile": false,
    "div_estimator": "exact",
    "ema_decay": 0.0,
    "logp_tol_scale": 1.0,
    "mean_free_prior": true,
    "n_eps": 1,
    "net": {
      "_target_": "src.models.neural_networks.egnn.egnn_dynamics_transferable_md.EGNNDynamicsTransferableMD",
      "channels": 256,
      "num_aa_max": "${data.num_aa_max}",
      "num_aa_min": "${data.num_aa_min}",
      "num_atoms": "${data.num_atoms}",
      "num_dimensions": "${data.num_dimensions}",
      "num_layers": 9
    },
    "optimizer": {
      "_partial_": true,
      "_target_": "torch.optim.AdamW",
      "betas": [
        0.9,
        0.999
      ],
      "lr": 0.0005,
      "weight_decay": 0.0
    },
    "output_dir": "${paths.output_dir}",
    "rtol": 0.0001,
    "sampling_config": {
      "batch_size": 4,
      "clip_reweighting_logits": 0.002,
      "num_proposal_samples": 10000,
      "num_smc_samples": 10000,
      "num_test_proposal_samples": 10000,
      "subset_idx": "${seed}",
      "use_com_adjustment": false
    },
    "scheduler": {
      "_partial_": true,
      "_target_": "torch.optim.lr_scheduler.StepLR",
      "gamma": 0.25,
      "step_size": 125
    },
    "sigma": 0.01,
    "smc_sampler": null
  },
  "paths": {
    "data_dir": "${paths.scratch_dir}/many-peptides-md",
    "log_dir": "${paths.scratch_dir}/logs",
    "output_dir": "${hydra:runtime.output_dir}",
    "root_dir": "${oc.env:PROJECT_ROOT}",
    "scratch_dir": "${oc.env:SCRATCH_DIR}/transferable-samplers",
    "work_dir": "${hydra:runtime.cwd}"
  },
  "seed": null,
  "state_dict_hf_path": "transferable/ecnf++_up_to_4aa.pth",
  "tags": [
    "dev"
  ],
  "task_name": "eval",
  "test": true,
  "torch_num_threads": 2,
  "trainer": {
    "_target_": "lightning.pytorch.trainer.Trainer",
    "accelerator": "gpu",
    "check_val_every_n_epoch": 10,
    "default_root_dir": "${paths.output_dir}",
    "deterministic": false,
    "devices": 1,
    "gradient_clip_val": 1.0,
    "inference_mode": false,
    "limit_test_batches": 1,
    "limit_val_batches": 1,
    "max_epochs": 40,
    "min_epochs": 1,
    "plugins": [
      {
        "_target_": "lightning.pytorch.plugins.environments.SLURMEnvironment",
        "auto_requeue": false
      }
    ]
  },
  "val": false
}
